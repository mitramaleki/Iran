import matplotlib.pyplot as plt
import matplotlib.image as mpimg
import os

def show_flag():
    """Display the Iranian flag SVG if present in this repo."""
    # Expected path of your SVG file within the repository
    flag_path = "/mnt/uploads/Flag_of_Iran_detailed.svg"

    if not os.path.exists(flag_path):
        print("⚠️  Flag_of_Iran_detailed.svg not found. Please upload it to /mnt/uploads/.")
    else:
        img = mpimg.imread(flag_path)
        plt.imshow(img)
        plt.axis("off")
        plt.title("🇮🇷  Flag of Iran")
        plt.show()
        print("✅  Flag displayed successfully.")

show_flag()
